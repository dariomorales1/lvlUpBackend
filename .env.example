# ============================================
# LevelUP Backend - Variables de Entorno
# ============================================
# Copiar este archivo a .env y completar los valores reales
# cp .env.example .env

# --- Base de Datos PostgreSQL ---
# IP privada del EC2-Data o hostname
DB_HOST=10.0.2.X
DB_PORT=5432
DB_NAME=lvlup_db
DB_USER=postgres
DB_PASSWORD=tu_password_seguro

# --- JWT ---
# Secret para firmar tokens JWT (usar un string largo y aleatorio)
JWT_SECRET=cambiar_por_un_secret_seguro_de_al_menos_32_caracteres

# --- Supabase Storage (imagenes de productos y avatares) ---
# URL de tu instancia Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
# Service Role Key de Supabase (NO la anon key)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Firebase (autenticacion) ---
# El archivo service-account.json debe estar en ./firebase/service-account.json
# Se monta como volumen read-only en el contenedor de auth-service
